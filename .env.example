# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=amazon_shopping_agent
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false

# Meilisearch Configuration
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_api_key

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# Browser Use Cloud API Configuration
BROWSER_USE_API_URL=https://api.cloud.browser-use.com
BROWSER_USE_API_KEY=bu_zsh7rKIzBW4VR75OG5yWFLd16X2__2AZIcqP987Dm1A

# Amazon Affiliate Configuration
AMAZON_AFFILIATE_TAG=your-affiliate-tag

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# Sync Schedule (cron expressions)
PRICE_REFRESH_CRON=0 */12 * * *
FULL_SYNC_CRON=0 0 * * *

# Polkadot payment
POLKADOT_NETWORK=testnet
POLKADOT_MERCHANT_ADDRESS=
POLKADOT_PAYMENT_AMOUNT_PLANCK=
POLKADOT_CURRENCY_SYMBOL=PAS

# x402-style paywall middleware
X402_ENABLED=true
X402_REQUIRE_HEALTHY=false

# Routescan API validation (Polkadot testnet - Etherscan-like API)
SCAN_API_KEY=
SCAN_BASE_URL=

