# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_URL=postgres://postgres:your_password@localhost:5432/amazon_shopping_agent
DB_DATABASE=amazon_shopping_agent
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false

# Apify Configuration
APIFY_API_TOKEN=your_apify_api_token

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# MPP (Machine Payment Protocol) - https://docs.tempo.xyz/guide/machine-payments
MPP_SECRET_KEY=
MPP_REALM=localhost

# Tempo blockchain payment
TEMPO_NETWORK=tempo-testnet
TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
TEMPO_CHAIN_ID=42431
TEMPO_MERCHANT_ADDRESS=
TEMPO_PATHUSD_ADDRESS=0x20c0000000000000000000000000000000000000
TEMPO_PAYMENT_AMOUNT_MICRO=1000000
TEMPO_PAYMENT_CURRENCY=pathUSD

# Polkadot payment (optional, for legacy verification)
POLKADOT_NETWORK=testnet
POLKADOT_MERCHANT_ADDRESS=
POLKADOT_PAYMENT_AMOUNT_PLANCK=
POLKADOT_CURRENCY_SYMBOL=PAS

# Routescan API (Polkadot verification)
SCAN_API_KEY=
SCAN_BASE_URL=

# Comagent webhook
COMAGENT_BASE_URL=http://localhost:3001
DEPOSIT_WEBHOOK_SECRET=
