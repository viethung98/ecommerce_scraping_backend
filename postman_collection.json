{
  "info": {
    "name": "Purch Shopping Agent API",
    "description": "AI-powered shopping agent with hybrid search, conversational AI, cart, checkout and USDC/Sui payment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "purch-shopping-agent",
    "version": "2.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "sampleAsin",
      "value": "B08N5WRWNW",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "user123",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string",
      "description": "Chat session UUID (populated from POST /chat response)"
    },
    {
      "key": "cartId",
      "value": "",
      "type": "string",
      "description": "Cart UUID (populated from GET /cart/:userId response)"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string",
      "description": "Order UUID (populated from POST /checkout response)"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "string",
      "description": "Payment UUID (populated from POST /payment/request response)"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check API health status and uptime"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Hybrid Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search?q=laptop&minPrice=500&maxPrice=2000&minRating=4&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["search"],
              "query": [
                { "key": "q", "value": "laptop", "description": "Search query (required)" },
                { "key": "minPrice", "value": "500", "description": "Minimum price filter" },
                { "key": "maxPrice", "value": "2000", "description": "Maximum price filter" },
                { "key": "minRating", "value": "4", "description": "Minimum rating (0-5)" },
                { "key": "page", "value": "1", "description": "Page number" },
                { "key": "limit", "value": "20", "description": "Results per page (max: 100)" },
                { "key": "category", "value": "", "description": "Product category filter", "disabled": true },
                { "key": "brand", "value": "", "description": "Brand filter", "disabled": true },
                { "key": "forceRealtime", "value": "false", "description": "Force realtime search", "disabled": true }
              ]
            },
            "description": "Smart hybrid routing between cached and realtime search"
          },
          "response": []
        },
        {
          "name": "Cached Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/cached?q=laptop&minPrice=500&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["search", "cached"],
              "query": [
                { "key": "q", "value": "laptop" },
                { "key": "minPrice", "value": "500" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Fast search from indexed Meilisearch database"
          },
          "response": []
        },
        {
          "name": "Realtime Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/realtime?q=laptop&minPrice=500&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["search", "realtime"],
              "query": [
                { "key": "q", "value": "laptop" },
                { "key": "minPrice", "value": "500" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Fresh data from Amazon via Browser Use Cloud API"
          },
          "response": []
        },
        {
          "name": "Get Product (Cached)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/cached/product/{{sampleAsin}}",
              "host": ["{{baseUrl}}"],
              "path": ["search", "cached", "product", "{{sampleAsin}}"]
            },
            "description": "Get product details from local database"
          },
          "response": []
        },
        {
          "name": "Get Product (Realtime)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/realtime/product/{{sampleAsin}}",
              "host": ["{{baseUrl}}"],
              "path": ["search", "realtime", "product", "{{sampleAsin}}"]
            },
            "description": "Get fresh product details from Amazon"
          },
          "response": []
        },
        {
          "name": "Search Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/status",
              "host": ["{{baseUrl}}"],
              "path": ["search", "status"]
            },
            "description": "Get search routing system status"
          },
          "response": []
        },
        {
          "name": "Popular Queries",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/popular?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["search", "popular"],
              "query": [{ "key": "limit", "value": "10" }]
            },
            "description": "Get most popular search queries"
          },
          "response": []
        },
        {
          "name": "Cached Search Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/cached/health",
              "host": ["{{baseUrl}}"],
              "path": ["search", "cached", "health"]
            },
            "description": "Check Meilisearch / cached search health"
          },
          "response": []
        },
        {
          "name": "Cached Search Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/cached/stats",
              "host": ["{{baseUrl}}"],
              "path": ["search", "cached", "stats"]
            },
            "description": "Get indexed product stats"
          },
          "response": []
        },
        {
          "name": "Realtime Search Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search/realtime/health",
              "host": ["{{baseUrl}}"],
              "path": ["search", "realtime", "health"]
            },
            "description": "Check Browser Use / Apify availability"
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI Chat",
      "item": [
        {
          "name": "Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.session_id) {",
                  "  pm.collectionVariables.set('sessionId', body.session_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"I'm looking for trail running shoes under $150\",\n  \"user_id\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Start a new chat session or continue an existing one. Pass session_id to continue. The AI will ask clarifying questions and then call the product search engine automatically."
          },
          "response": []
        },
        {
          "name": "Continue Chat Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{sessionId}}\",\n  \"message\": \"Trail running, budget around $130\",\n  \"user_id\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Continue an existing chat session with a follow-up message"
          },
          "response": []
        },
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chat/history?session_id={{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "history"],
              "query": [{ "key": "session_id", "value": "{{sessionId}}" }]
            },
            "description": "Retrieve user/assistant messages for a session"
          },
          "response": []
        },
        {
          "name": "Delete Chat Session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chat/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "{{sessionId}}"]
            },
            "description": "Deactivate a chat session"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('cartId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "{{userId}}"]
            },
            "description": "Get the active cart for a user. Creates one if it doesn't exist."
          },
          "response": []
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{sampleAsin}}\",\n  \"name\": \"Brooks Cascadia Trail Running Shoes\",\n  \"image\": \"https://example.com/shoe.jpg\",\n  \"size\": \"10\",\n  \"color\": \"Blue\",\n  \"price\": 129.99,\n  \"quantity\": 1,\n  \"retailer\": \"Amazon\",\n  \"product_url\": \"https://amazon.com/dp/{{sampleAsin}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/{{userId}}/items",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "{{userId}}", "items"]
            },
            "description": "Add a product to the user's cart. Increments quantity if same product+size+color already exists."
          },
          "response": []
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/{{userId}}/items/{{sampleAsin}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "{{userId}}", "items", "{{sampleAsin}}"]
            },
            "description": "Update quantity of an item. Set to 0 to remove it."
          },
          "response": []
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/{{userId}}/items/{{sampleAsin}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "{{userId}}", "items", "{{sampleAsin}}"]
            },
            "description": "Remove a specific product from the cart"
          },
          "response": []
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "{{userId}}"]
            },
            "description": "Remove all items from the user's cart"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Checkout (Create Order)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.order_id) {",
                  "  pm.collectionVariables.set('orderId', body.order_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cart_id\": \"{{cartId}}\",\n  \"user_id\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["checkout"]
            },
            "description": "Create an order from the cart. Returns order details and USDC/Sui payment info."
          },
          "response": []
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?user_id={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [{ "key": "user_id", "value": "{{userId}}" }]
            },
            "description": "Get all orders for a user, sorted by newest first"
          },
          "response": []
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}"]
            },
            "description": "Get order details and current status"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payment (Sui USDC)",
      "item": [
        {
          "name": "Generate Payment Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.payment_id) {",
                  "  pm.collectionVariables.set('paymentId', body.payment_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"{{orderId}}\",\n  \"user_id\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payment/request",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "request"]
            },
            "description": "Generate a USDC on Sui payment request. Returns recipient address, amount, and expiry (15 min). Use the returned values with @mysten/payment-kit on the frontend."
          },
          "response": []
        },
        {
          "name": "Payment Webhook (Confirm Tx)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_id\": \"{{paymentId}}\",\n  \"tx_hash\": \"<sui_tx_digest>\",\n  \"status\": \"confirmed\",\n  \"sender_address\": \"0x<user_sui_wallet>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payment/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "webhook"]
            },
            "description": "Called by frontend after user signs Sui transaction. Backend verifies on-chain (amount, recipient, USDC type) then marks order as paid."
          },
          "response": []
        },
        {
          "name": "Verify Payment Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payment/verify/{{paymentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "verify", "{{paymentId}}"]
            },
            "description": "Poll payment status: pending | processing | confirmed | failed | expired"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Price Alerts",
      "item": [
        {
          "name": "Get Price History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/price/{{sampleAsin}}/history",
              "host": ["{{baseUrl}}"],
              "path": ["price", "{{sampleAsin}}", "history"]
            },
            "description": "Get price history for a product"
          },
          "response": []
        },
        {
          "name": "Get Price Analytics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/price/{{sampleAsin}}/analytics",
              "host": ["{{baseUrl}}"],
              "path": ["price", "{{sampleAsin}}", "analytics"]
            },
            "description": "Get min/max/avg price analytics for a product"
          },
          "response": []
        },
        {
          "name": "Create Price Alert",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asin\": \"{{sampleAsin}}\",\n  \"userId\": \"{{userId}}\",\n  \"targetPrice\": 99.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/price/alerts",
              "host": ["{{baseUrl}}"],
              "path": ["price", "alerts"]
            },
            "description": "Create a price drop alert for a product"
          },
          "response": []
        },
        {
          "name": "Get My Price Alerts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/price/alerts?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["price", "alerts"],
              "query": [{ "key": "userId", "value": "{{userId}}" }]
            },
            "description": "Get all active price alerts for a user"
          },
          "response": []
        },
        {
          "name": "Delete Price Alert",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/price/alerts/:alertId",
              "host": ["{{baseUrl}}"],
              "path": ["price", "alerts", ":alertId"],
              "variable": [{ "key": "alertId", "value": "uuid-here" }]
            },
            "description": "Remove a price alert"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin (Sync)",
      "item": [
        {
          "name": "Trigger Full Sync",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queries\": [\"laptop\", \"headphones\", \"phone\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/sync/trigger/full",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "sync", "trigger", "full"]
            },
            "description": "Trigger full product synchronization from Amazon"
          },
          "response": []
        },
        {
          "name": "Trigger Price Refresh",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/sync/trigger/price-refresh",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "sync", "trigger", "price-refresh"]
            },
            "description": "Refresh prices for stale products"
          },
          "response": []
        },
        {
          "name": "Get Sync Job Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/sync/status/:jobId",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "sync", "status", ":jobId"],
              "variable": [{ "key": "jobId", "value": "uuid-here" }]
            },
            "description": "Get status of a specific sync job"
          },
          "response": []
        },
        {
          "name": "Get Recent Sync Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/sync/jobs?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "sync", "jobs"],
              "query": [{ "key": "limit", "value": "10" }]
            },
            "description": "List recent sync jobs"
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": { "type": "text/javascript", "exec": [""] }
    },
    {
      "listen": "test",
      "script": { "type": "text/javascript", "exec": [""] }
    }
  ]
}
